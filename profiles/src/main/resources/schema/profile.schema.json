{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/kosherjava/profile.schema.json",
  "title": "Profile",
  "type": "object",
  "required": ["version", "key", "displayName", "times"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2.0"]
    },
    "key": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "labels": {
      "type": "object",
      "description": "Optional extra labels/metadata (e.g., lang).",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "times": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/TimeEntry" }
    }
  },
  "additionalProperties": false,

  "definitions": {
    "TimeEntry": {
      "type": "object",
      "required": ["id", "label", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/definitions/Target" }
      },
      "additionalProperties": false
    },

    "Target": {
      "oneOf": [
        { "$ref": "#/definitions/ExternalTarget" },
        { "$ref": "#/definitions/InternalTarget" }
      ]
    },

    "ExternalTarget": {
      "type": "object",
      "required": ["type", "externalName"],
      "properties": {
        "type": { "const": "EXTERNAL_NAME" },
        "externalName": {
          "type": "string",
          "minLength": 1,
          "description": "Exact KosherJava method name (e.g., getSeaLevelSunset)"
        }
      },
      "additionalProperties": false
    },

    "InternalTarget": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "INTERNAL" },
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*(\\.[A-Z0-9_\\.]+)?$",
          "description": "Canonical internal id (e.g., SFARADI_OR_HACHAIM.ALOS_72_ZMANIYOT_ASTRO)"
        },
        "params": {
          "type": "object",
          "description": "Optional parameter bag; keys vary by internal method.",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      },
      "additionalProperties": false
    }
  }
}